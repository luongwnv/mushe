# Spotify app credentials (developer.spotify.com → create app).
# Client Credentials flow only — NO user login, NO Premium needed (metadata only).
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Port the resolver listens on (must match VITE_RESOLVER_URL in web/.env).
PORT=8787

# Comma-separated allowed origins for CORS, or "*" to reflect any origin.
CORS_ORIGIN=http://localhost:5173

# Lavalink node (used for reliable YouTube search via its youtube-plugin).
LAVALINK_URL=http://localhost:2333
LAVALINK_PASSWORD=youshallnotpass

# OPTIONAL: Supabase service role key, only needed if the resolver writes the
# track_resolution cache directly. The web client can also pass results through.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
